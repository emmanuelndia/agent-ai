# 1. Utiliser l'image Playwright
FROM mcr.microsoft.com/playwright:v1.49.0-jammy

# 2. Dossier de travail
WORKDIR /app

# 3. Copier les fichiers de dépendances
COPY package*.json ./

# 4. Installer les dépendances (y compris typescript pour le build)
RUN npm install

# 5. Copier tout le code source
COPY . .

# 6. COMPILER le TypeScript en JavaScript (Crucial !)
# Cela va créer un dossier /dist avec des fichiers .js
RUN npx tsc

# 7. Installer Chromium pour Playwright
RUN npx playwright install chromium

# 8. Exposer le port
EXPOSE 3000

# 9. LANCER la version compilée (Node JS pur, pas de ts-node)
# On utilise le script "start" de ton package.json
CMD ["npm", "start"]