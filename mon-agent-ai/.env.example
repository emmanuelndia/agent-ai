# Clés API pour l'agent
# Choisissez-en une seule : Google OU Groq

# Option 1 : Google Gemini (recommandé)
GOOGLE_API_KEY=votre_clé_google_api_ici

# Option 2 : Groq (alternative)
# GROQ_API_KEY=votre_clé_groq_ici

# E2B Sandbox (pour navigation cloud sécurisée)
E2B_API_KEY=votre_clé_e2b_ici

# Autres clés API (optionnelles)
# TAVILY_API_KEY=votre_clé_tavily_ici
