  "description": "Agent IA autonome avec navigation web, gestion de fichiers et création de comptes automatiques",
  "main": "index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "agent": "ts-node src/agent-complet.ts",
    "server": "ts-node src/server.ts",
