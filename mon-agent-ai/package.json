{
  "name": "mon-agent-ai",
  "version": "1.0.0",
  "description": "Agent IA autonome avec navigation web, gestion de fichiers et cr\u00e9ation de comptes automatiques",
  "main": "index.js",
  "scripts": {
    "build": "npx esbuild src/server.ts --bundle --platform=node --target=node20 --outfile=dist/server.js --format=cjs --external:@e2b/code-interpreter --external:@google/generative-ai --external:@langchain/* --external:playwright --external:express --external:cors --external:dotenv",
    "build:simple": "npx esbuild src/server.ts --platform=node --target=node20 --outfile=dist/server.js --bundle=false",
    "start": "node dist/server.js",
    "dev": "ts-node src/index.ts",
    "console": "ts-node src/cli.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/node": "^25.3.2",
    "esbuild": "^0.24.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@e2b/code-interpreter": "^2.3.3",
    "@google/generative-ai": "^0.24.1",
    "@langchain/community": "^0.3.59",
    "@langchain/core": "^0.3.80",
    "@langchain/google-genai": "^0.0.24",
    "@langchain/groq": "^0.0.15",
    "@langchain/langgraph": "^0.2.74",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "langchain": "^0.3.37",
    "playwright": "^1.58.2",
    "zod": "^3.25.76",
    "@langchain/openai": "^0.3.0",
    "@langchain/cohere": "^0.3.0",
    "@langchain/mistralai": "^0.1.0"
  }
}