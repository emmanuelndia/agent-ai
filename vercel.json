{
  "version": 2,
  "builds": [
    {"src": "mon-agent-ai/src/server.ts", "use": "@vercel/node"},
    {"src": "frontend/package.json", "use": "@vercel/next"}
  ],
  "routes": [
    {"src": "/api/(.*)", "dest": "/mon-agent-ai/src/server.ts"},
    {"src": "/(.*)", "dest": "/frontend/$1"}
  ],
  "env": {"NODE_ENV": "production"},
  "functions": {
    "mon-agent-ai/src/server.ts": {"maxDuration": 30}
  }
}